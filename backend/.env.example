# KrishiConnect Backend — Environment Variables
# Copy this file to .env and fill in real values

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=krishiconnect

# ── Twilio ────────────────────────────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── data.gov.in API ───────────────────────────────────────────────────────────
# Register at: https://data.gov.in/user/register (free, instant approval)
DATA_GOV_API_KEY=579b464db66ec23d318f0000

# ── Optional: MSG91 (better Indian delivery than Twilio) ─────────────────────
# MSG91_API_KEY=your_key
# MSG91_SENDER_ID=KRISHI
